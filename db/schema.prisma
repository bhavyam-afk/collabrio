generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String           @id @default(cuid())
  email          String           @unique
  username       String           @unique
  passwordHash   String
  userType       UserType
  onboarding     OnboardingStatus @default(PENDING)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  brandProfile   BrandProfile?
  creatorProfile CreatorProfile?
  notifications  Notification[]
  wallet         Wallet?
}

model CreatorProfile {
  id                 String                     @id @default(cuid())
  userId             String                     @unique
  bio                String?
  location           String?
  niche              String?
  profilePicUrl      String?
  introClipUrl       String?
  nicheTags          String[]
  portfolio          Json?
  mlScore            Float?
  category           CreatorCategory?
  platformLinks      Json?
  followerCount      Int                        @default(0)
  collaborations     Collaboration[]
  availabilities     CreatorAvailability[]
  dailyAnalytics     CreatorDailyAnalytics[]
  user               User                       @relation(fields: [userId], references: [id])
  socialAccounts     CreatorSocialAccount[]
  rawSocialSnapshots CreatorSocialRawSnapshot[]
  packages           Package[]
  fullAnalytics      creatorFullAnalytics?

  @@index([userId])
}

model BrandProfile {
  id             String             @id @default(cuid())
  userId         String             @unique
  logoUrl        String?
  bio            String?
  industryTags   String[]
  socialLinks    Json?
  plan           SubscriptionPlan   @default(BASIC)
  user           User               @relation(fields: [userId], references: [id])
  subscription   BrandSubscription?
  collaborations Collaboration[]

  @@index([userId])
}

model Package {
  id                    String                 @id @default(cuid())
  creatorId             String
  title                 String
  description           String?
  thumbnailUrl          String?
  mediaType             String
  deliverables          String[]
  deliveryTimeDays      Int
  price                 Decimal                @db.Decimal(10, 2)
  packageStatus         PackageStatus          @default(DRAFT)
  collaborations        Collaboration[]
  creator               CreatorProfile         @relation(fields: [creatorId], references: [id])
  packageCollaborations PackageCollaboration[]

  @@index([creatorId])
}

model Collaboration {
  id            String                @id @default(cuid())
  creatorId     String
  brandId       String
  packageId     String
  collabStatus  CollabStatus          @default(PENDING)
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  PaymentStatus PaymentStatus         @default(UNPAID)
  brand         BrandProfile          @relation(fields: [brandId], references: [id])
  creator       CreatorProfile        @relation(fields: [creatorId], references: [id])
  package       Package               @relation(fields: [packageId], references: [id])
  content       PackageCollaboration?

  @@index([creatorId])
  @@index([brandId])
  @@index([packageId])
}

model PackageCollaboration {
  id                  String        @id @default(cuid())
  collabId            String        @unique
  packageId           String
  contentStatus       ContentStatus @default(NOT_SUBMITTED)
  contentDraft        Json?
  revisionCount       Int           @default(0)
  draftSubmittedAt    DateTime?
  PaymentStatus       PaymentStatus @default(UNPAID)
  brandFeedback       String?
  draftApprovedAt     DateTime?
  publishedContentUrl String?
  publishedAt         DateTime?
  collaboration       Collaboration @relation(fields: [collabId], references: [id])
  package             Package       @relation(fields: [packageId], references: [id])
}

model Wallet {
  id                   String        @id @default(cuid())
  userId               String        @unique
  walletType           WalletType
  currentBalance       Decimal       @default(0) @db.Decimal(12, 2)
  pendingBalance       Decimal       @default(0) @db.Decimal(12, 2)
  totalEarned          Decimal       @default(0) @db.Decimal(12, 2)
  totalSpent           Decimal       @default(0) @db.Decimal(12, 2)
  outgoingTransactions Transaction[] @relation("FromWallet")
  incomingTransactions Transaction[] @relation("ToWallet")
  user                 User          @relation(fields: [userId], references: [id])

  @@index([userId])
}

model Transaction {
  id                String            @id @default(cuid())
  fromWalletId      String?
  toWalletId        String?
  amount            Decimal           @db.Decimal(12, 2)
  type              TransactionType
  status            TransactionStatus @default(PENDING)
  collabId          String?
  externalPaymentId String?
  externalOrderId   String?
  provider          String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  fromWallet        Wallet?           @relation("FromWallet", fields: [fromWalletId], references: [id])
  toWallet          Wallet?           @relation("ToWallet", fields: [toWalletId], references: [id])

  @@index([fromWalletId])
  @@index([toWalletId])
  @@index([collabId])
  @@index([externalPaymentId])
}

model BrandSubscription {
  id                     String           @id @default(cuid())
  brandId                String           @unique
  plan                   SubscriptionPlan @default(BASIC)
  currentPeriodStart     DateTime
  currentPeriodEnd       DateTime
  razorpaySubscriptionId String?
  razorpayPlanId         String?
  createdAt              DateTime         @default(now())
  updatedAt              DateTime         @updatedAt
  brand                  BrandProfile     @relation(fields: [brandId], references: [id])

  @@index([brandId])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  message   String
  read      Boolean          @default(false)
  collabId  String?
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id])

  @@index([userId, read])
}

model CreatorSocialAccount {
  id             String         @id @default(cuid())
  creatorId      String
  platform       String
  accessToken    String
  tokenExpiresAt DateTime?
  igAccountId    String?
  pageId         String?
  connected      Boolean        @default(false)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  creator        CreatorProfile @relation(fields: [creatorId], references: [id])

  @@unique([creatorId, platform])
}

model CreatorSocialRawSnapshot {
  id        String         @id @default(cuid())
  creatorId String
  platform  String
  rawData   Json
  fetchedAt DateTime       @default(now())
  creator   CreatorProfile @relation(fields: [creatorId], references: [id])

  @@index([creatorId, fetchedAt])
}

model CreatorDailyAnalytics {
  id           String         @id @default(cuid())
  creatorId    String
  date         DateTime
  followers    Int
  reach        Int
  impressions  Int
  engagements  Int
  likes        Int
  comments     Int
  shares       Int
  saves        Int
  replies      Int
  profileViews Int
  createdAt    DateTime       @default(now())
  creator      CreatorProfile @relation(fields: [creatorId], references: [id])

  @@unique([creatorId, date])
  @@index([creatorId, date])
}

model CreatorAvailability {
  id        String             @id @default(cuid())
  creatorId String
  date      DateTime
  status    AvailabilityStatus
  reason    String?
  createdAt DateTime           @default(now())
  creator   CreatorProfile     @relation(fields: [creatorId], references: [id])

  @@unique([creatorId, date])
  @@index([creatorId, date])
}

model creatorFullAnalytics {
  id             String         @id @default(cuid())
  creatorId      String         @unique
  followers      Int
  reach          Int
  impressions    Int
  engagements    Int
  likes          Int
  comments       Int
  shares         Int
  saves          Int
  replies        Int
  profileViews   Int
  engagementRate Float
  updatedAt      DateTime       @updatedAt
  creator        CreatorProfile @relation(fields: [creatorId], references: [id])
}

enum UserType {
  CREATOR
  BRAND
}

enum OnboardingStatus {
  PENDING
  COMPLETE
}

enum PackageStatus {
  ACTIVE
  DRAFT
  DELETED
}

enum CollabStatus {
  PENDING
  ACTIVE
  COMPLETED
  CANCELLED
}

enum ContentStatus {
  NOT_SUBMITTED
  SUBMITTED
  IMPROVEMENT_REQUESTED
  APPROVED
  REJECTED
}

enum WalletType {
  CREATOR
  BRAND
  PLATFORM
}

enum TransactionType {
  BRAND_PAYMENT
  CREATOR_EARNING
  PLATFORM_FEE
  PAYOUT
  REFUND
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
  INWALLET
}

enum PaymentStatus {
  UNPAID
  BRAND_PAID
  PLATFORM_HOLD
  CREATOR_PAID
  REFUNDED
}

enum CreatorCategory {
  NANO
  MICRO
  MACRO
  CELEB
}

enum AvailabilityStatus {
  AVAILABLE
  UNAVAILABLE
  TENTATIVE
}

enum SubscriptionPlan {
  BASIC
  PRO
  BUSINESS
}

enum NotificationType {
  COLLAB_INVITE
  DRAFT_SUBMITTED
  DRAFT_APPROVED
  IMPROVEMENT_REQUESTED
  PAYMENT_RECEIVED
  PAYOUT_PROCESSED
}
